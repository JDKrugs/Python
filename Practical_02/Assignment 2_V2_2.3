# Display title
print("ASCII and Character conversion")

# Convert character to ASCII value
character = input("Enter character: ")
ascii_value = ord(character)
print("The ASCII value is: " + str(ascii_value))

# Convert ASCII value to character
ascii_input = int(input("Enter the ASCII value: "))
character_result = chr(ascii_input)
print("The Character is: " + character_result)
