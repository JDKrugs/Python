# Get input from user
total_boerewors = int(input("Enter the total number of boerewors pieces: "))
guests = int(input("Enter the number of guests: "))

# Calculate leftover pieces using modulo operator
leftover = total_boerewors % guests

# Display result
print(f"Pieces of boerewors left over: {leftover}")
