# Get input from user
power = float(input("Enter the appliance power in watts (W): "))
time = float(input("Enter the duration the appliance is used in hours: "))

# Calculate energy consumption in kWh
energy_kwh = (power * time) / 1000

# Display result
print(f"Energy Consumption: {energy_kwh} kWh")
