# Concatenated values
print("Concatenated values")
age1_str = input("Enter your age: ")
friend_age_str = input("Enter the age of your friend: ")
print("Result: " + age1_str + friend_age_str)

# Sum values
print("Sum values")
age1_int = int(input("Enter your age: "))
friend_age_int = int(input("Enter the age of your friend: "))
sum_ages = age1_int + friend_age_int
print("Result: " + str(sum_ages))

# Average age
average_age = (age1_int + friend_age_int) / 2
print("Average age: " + str(average_age))
