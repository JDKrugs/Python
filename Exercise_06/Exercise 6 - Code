# Question 10
def print_menu():
    print("1. Multiply")
    print("2. Divide")
    print("3. Sum")
    print("4. Subtract")

def operate(choice, a, b):
    if choice == "1":
        print(a * b)
    elif choice == "2":
        if b == 0:
            print("Cannot divide by zero")
        else:
            print(a / b)
    elif choice == "3":
        print(a + b)
    elif choice == "4":
        print(a - b)
    else:
        print("Invalid choice")

def main_q10():
    print_menu()
    ch = input("Choose an option (1-4):\n")
    a_input = input("Enter first number:\n")
    b_input = input("Enter second number:\n")
    try:
        a = float(a_input)
    except:
        a = 0.0
    try:
        b = float(b_input)
    except:
        b = 0.0
    operate(ch, a, b)

if __name__ == "__main__":
    main_q10()
