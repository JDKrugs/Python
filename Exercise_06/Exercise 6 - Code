# Question 8
def print_evens(n):
    try:
        limit = int(n)
    except:
        limit = 0
    for i in range(0, limit + 1):
        if i % 2 == 0:
            print(i)

def main_q8():
    n = input("Enter an integer to print evens up to:\n")
    print_evens(n)

