import math
def area_of_circle(radius):
    try:
        r = float(radius)
    except:
        r = 0.0
    area = math.pi * r * r
    return round(area, 2)

def main_q7():
    r = input("Enter radius:\n")
    print("Area:", area_of_circle(r))

if __name__ == "__main__":
    main_q7()

# Question 8
import random
def guessing_game_once(guess, target):
    try:
        g = int(guess)
    except:
        g = -1
    return g == target

def guessing_game():
    target = random.randint(1, 50)
    tries = 0
    while True:
        guess = input("Guess a number (1-50):\n")
        tries += 1
        if guessing_game_once(guess, target):
            return tries
        else:
            print("Wrong, try again.")

def main_q8():
    tries = guessing_game()
    print("Correct! Tries:", tries)

if __name__ == "__main__":
    main_q8()

