    main_q5()

# Question 6
def average_speed(distance, time):
    try:
        d = float(distance)
    except:
        d = 0.0
    try:
        t = float(time)
    except:
        t = 1.0
    if t == 0:
        return 0.0
    return d / t

def main_q6():
    dist = input("Enter distance (km):\n")
    tim = input("Enter time (hours):\n")
    print("Average speed (km/h):", average_speed(dist, tim))

if __name__ == "__main__":
    main_q6()

