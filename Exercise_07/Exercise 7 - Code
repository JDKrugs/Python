def celsius_to_fahrenheit(c):
    try:
        c_val = float(c)
    except:
        c_val = 0.0
    return (c_val * 9 / 5) + 32

def main_q2():
    c = input("Enter temperature in Celsius:\n")
    f = celsius_to_fahrenheit(c)
    print("Fahrenheit:", f)

if __name__ == "__main__":
    main_q2()

