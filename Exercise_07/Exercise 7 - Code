# Question 10
def factorial(n):
    try:
        k = int(n)
    except:
        k = 0
    if k <= 1:
        return 1
    else:
        return k * factorial(k - 1)

def main_q10():
    num = input("Enter a positive integer:\n")
    try:
        nval = int(num)
    except:
        nval = 0
    if nval < 0:
        print("Invalid input")
    else:
        print("Factorial:", factorial(nval))

if __name__ == "__main__":
    main_q10()
