# Question 4
def q4_safe_division():
    a = input("Enter first number:\n")
    b = input("Enter second number:\n")
    try:
        x = float(a)
        y = float(b)
        result = x / y
    except ValueError:
        print("Error: invalid input")
    except ZeroDivisionError:
        print("Error: division by zero")
    else:
        print("Result:", result)

if __name__ == "__main__" and False:
    q4_safe_division()

