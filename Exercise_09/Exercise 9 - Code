# Question 6
def q6_read_and_sum_sales():
    total = 0.0
    try:
        with open("sales.txt", "r", encoding="utf-8") as f:
            for i in range(3):
                line = f.readline()
                if not line:
                    break
                try:
                    total += float(line.strip())
                except ValueError:
                    continue
    except FileNotFoundError:
        print("Error: sales.txt not found")
        return
    print("Total:", total)

if __name__ == "__main__" and False:
    q6_read_and_sum_sales()

