# Question 8
def q8_trip_contributions_with_validation():
    entries = []
    for i in range(3):
        name = input(f"Enter name {i+1}:\n").strip()
        amt = input(f"Enter contribution for {name}:\n").strip()
        try:
            val = float(amt)
        except ValueError:
            print("Invalid amount, using 0.0")
            val = 0.0
        entries.append((name, val))
    try:
        with open("Trip.txt", "w", encoding="utf-8") as f:
            for name, val in entries:
                f.write(f"{name},{val}\n")
    except Exception:
        print("Error: could not write Trip.txt")

if __name__ == "__main__" and False:
    q8_trip_contributions_with_validation()

