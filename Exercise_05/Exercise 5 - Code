# Question 8
height = 0
days = 0
peak = 5000
while height < peak:
    climb_input = input("\nEnter climb for day " + str(days+1) + " (300-700):\n")
    try:
        climbed = int(climb_input)
    except:
        climbed = 0
    if climbed < 300:
        climbed = 300
    if climbed > 700:
        climbed = 700
    days += 1
    height += climbed
    if height >= peak:
        print("Reached the top in " + str(days) + " days")
        break
    height -= 150
    remaining = peak - height
    if remaining < 0:
        remaining = 0
    print("After night slide you still need:\n" + str(remaining) + " m")

# Question 9
import random
target = random.randint(1, 100)
tries = 0
while True:
    guess_input = input("\nGuess the number (1-100):\n")
    try:
        guess = int(guess_input)
    except:
        guess = 0
    tries += 1
    if guess == target:
        print("Correct! You took " + str(tries) + " tries.")
        break
    elif guess < target:
        print("Too low")
    else:
        print("Too high")

# Question 10
def is_prime(x):
    if x <= 1:
        return False
    if x <= 3:
        return True
    if x % 2 == 0:
        return False
    i = 3
    while i * i <= x:
        if x % i == 0:
            return False
        i += 2
    return True

while True:
    num_input = input("\nEnter a number to check for prime:\n")
    try:
        num = int(num_input)
    except:
        num = 0
    if is_prime(num):
        print("That is a prime number:\n" + str(num))
        break
    else:
        print("Not prime. Enter another number.")
