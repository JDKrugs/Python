# Question 3
num_input = input("\nHow many modules?\n")
try:
    count = int(num_input)
except:
    count = 0
total = 0.0
for i in range(count):
    mark_input = input("Enter mark for module " + str(i+1) + ":\n")
    try:
        mark = float(mark_input)
    except:
        mark = 0.0
    total += mark
average = 0.0 if count == 0 else total / count
print("Average:\n" + "{:.2f}".format(average))
if average >= 60:
    print("You can apply for honours")
else:
    print("You cannot apply for honours")

# Question 4
n_input = input("\nEnter a number to find its factorial:\n")
try:
    n = int(n_input)
except:
    n = 0
fact = 1
if n < 0:
    fact = 0
else:
    for k in range(1, n + 1):
        fact *= k
print("Factorial:\n" + str(fact))

# Question 5
fib_input = input("\nEnter how many Fibonacci terms to generate:\n")
try:
    terms = int(fib_input)
except:
    terms = 0
a, b = 0, 1
seq = []
for _ in range(terms):
    seq.append(str(a))
    a, b = b, a + b
print("Fibonacci:\n" + " ".join(seq))

