# List Operations

# Create initial list
numbers = [10, 20, 30, 40, 50]

print(f"Original list: {numbers}")

# a) Append 60 to the end
numbers.append(60)
print(f"After appending 60: {numbers}")

# b) Insert 25 at third position (index 2)
numbers.insert(2, 25)
print(f"After inserting 25 at position 3: {numbers}")

# c) Remove 40
numbers.remove(40)
print(f"After removing 40: {numbers}")

# d) Reverse the list and print it
numbers.reverse()
print(f"Final list after reversing: {numbers}")
