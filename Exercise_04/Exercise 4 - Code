# Question 3
# commission for multiple employees (repeated code solution)
num_input = input("\nHow many employees?\n")
try:
    num_employees = int(num_input)
except:
    num_employees = 0
count = 0
while count < num_employees:
    emp_sales_input = input("Enter sales for employee " + str(count+1) + ":\n")
    emp_rate_input = input("Enter commission rate (percent) for employee " + str(count+1) + ":\n")
    try:
        emp_sales = float(emp_sales_input)
    except:
        emp_sales = 0.0
    try:
        emp_rate = float(emp_rate_input) / 100.0
    except:
        emp_rate = 0.0
    emp_comm = emp_sales * emp_rate
    print("Employee " + str(count+1) + " commission:\n" + str(emp_comm))
    count += 1

# Question 4
# sum a fixed number (5) of values using accumulator
total = 0.0
i = 0
while i < 5:
    val_input = input("\nEnter value " + str(i+1) + " to add:\n")
    try:
        val = float(val_input)
    except:
        val = 0.0
    total += val
    i += 1
print("Total sum:\n" + str(total))

# Question 5
# draw a square of given size and character
size_input = input("\nEnter square size (integer):\n")
char_input = input("Enter a character to draw the square with:\n")
try:
    size = int(size_input)
except:
    size = 0
ch = char_input[0] if len(char_input) > 0 else "*"
row = 0
while row < size:
    print(ch * size)
    row += 1

