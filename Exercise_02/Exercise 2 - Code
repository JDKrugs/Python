# Question 9
try:
    price = float(input("\nEnter the product price:\n"))
except:
    price = 0.0
try:
    discount_percent = float(input("Enter the discount percentage (e.g., 20):\n"))
except:
    discount_percent = 0.0
discount_amount = price * (discount_percent / 100)
final_price = price - discount_amount
print("Original price:\n" + "{:.2f}".format(price))
print("Discount amount:\n" + "{:.2f}".format(discount_amount))
print("Final price:\n" + "{:.2f}".format(final_price))

