# Guess the Number Game

import random

def guess_number():
    # Seed the random number generator with 10 for consistent results
    random.seed(10)
    
    # Generate a random integer between 1 and 100
    secret_number = random.randint(1, 100)
    
    # Initialize variables
    guess_count = 0
    is_playing = True
    
    print("Welcome to the Guess the Number Game!")
    print("Try to guess the secret number between 1 and 100.")
    print("Enter 0 at any time to quit the game.\n")
    
    # Loop until user guesses correctly or quits
    while is_playing:
        try:
            # Get user's guess
            guess = int(input("Enter your guess: "))
            
            # Check if user wants to quit
            if guess == 0:
                print("Thanks for playing! Goodbye!")
                is_playing = False
                break
            
            # Increment guess count
            guess_count += 1
            
            # Provide feedback
            if guess < secret_number:
                print("Your guess is too low. Try again.\n")
            elif guess > secret_number:
                print("Your guess is too high. Try again.\n")
            else:
                # User guessed correctly
                print(f"Congratulations! You guessed the correct number: {secret_number}")
                print(f"Total number of guesses: {guess_count}")
                is_playing = False
        
        except ValueError:
            print("Please enter a valid integer.\n")

def main():
    # Call the guess_number function
    guess_number()

# Call the main function
if __name__ == "__main__":
    main()
