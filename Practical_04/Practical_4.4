# Check if student number is valid based on digit sum and digit count

while True:
    # Get student number from user
    student_number = input("Enter a student number (or 0 to exit): ")
    
    # Check if user wants to exit
    if student_number == "0":
        print("Thank you")
        break
    
    # Ensure the student number is larger than 0
    if int(student_number) <= 0:
        print("Please enter a valid student number larger than 0.")
        continue
    
    # Calculate sum of digits
    digit_sum = sum(int(digit) for digit in student_number)
    
    # Get number of digits
    num_digits = len(student_number)
    
    # Check if valid (sum of digits % number of digits == 0)
    if digit_sum % num_digits == 0:
        print("Valid")
    else:
        print("Invalid")
    
    # Ask if user wants to enter another student number
    response = input("Do you want to enter another student number? (Yes/No): ").lower()
    if response == "no" or response == "n":
        break
