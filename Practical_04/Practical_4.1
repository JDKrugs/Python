# Calculate the sum of the first N even numbers

# Get input from user
N = int(input("Enter a positive integer N: "))

# Initialize sum to 0
total_sum = 0

# Loop from 1 to N and calculate sum of even numbers
for i in range(1, N + 1):
    even_number = 2 * i
    total_sum += even_number

# Display the result using f-string
print(f"The sum of the first {N} even numbers is {total_sum}")
