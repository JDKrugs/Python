# Find all perfect numbers up to N (where a perfect number equals the sum of its proper divisors)

# Get input from user
while True:
    N = int(input("Enter a positive integer N: "))
    
    # Validate that N is larger than 0
    if N <= 0:
        print("Please enter a positive integer larger than 0.")
        continue
    break

# Find and display all perfect numbers up to N
print(f"\nPerfect numbers up to {N}:")
found_any = False

for num in range(2, N + 1):
    # Calculate sum of proper divisors
    divisor_sum = 0
    for divisor in range(1, num):
        if num % divisor == 0:
            divisor_sum += divisor
    
    # Check if perfect number
    if divisor_sum == num:
        print(f"{num}")
        found_any = True

# If no perfect numbers found
if not found_any:
    print(f"No perfect numbers found up to {N}")
