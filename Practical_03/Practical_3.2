result = ""

temp = int(input("Enter a temperature (in Celsius): "))

if temp < 0:
    result = "Freezing Cold"
elif temp <= 10:
    result = "Cold"
elif temp <= 20:
    result = "Cool"
elif temp <= 30:
    result = "Warm"
else:
    result = "Scorching"

print("The temperature is", result)

